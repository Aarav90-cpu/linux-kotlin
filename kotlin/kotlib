#!/usr/bin/env bash
# =============================================================================
#  kotlib — Koinux system-wide Kotlin/Android/Compose library manager
#  Lives at: /usr/local/bin/kotlib
#  Requires: sudo for any write operation
# =============================================================================

set -euo pipefail

# ── Paths ────────────────────────────────────────────────────────────────────
KERNEL_SRC="${KERNEL_SRC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
readonly PROJECT_DIR="${KERNEL_SRC}/samples/android/minimal"
readonly TOML="${PROJECT_DIR}/gradle/libs.versions.toml"
readonly BUILD_GRADLE="${PROJECT_DIR}/app/build.gradle"
readonly SETTINGS_GRADLE="${PROJECT_DIR}/settings.gradle"
readonly GRADLE_CACHE="${KERNEL_SRC}/.gradle-cache/caches"
readonly GRADLE_BIN="${KERNEL_SRC}/.gradle-tools/gradle/bin/gradle"

# ── ANSI colours (kept minimal — this is a system tool, not a party) ─────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}${1}${RESET}"; }
success() { echo -e "${GREEN}${1}${RESET}"; }
warn()    { echo -e "${YELLOW}${1}${RESET}"; }
die()     { echo -e "${RED}✖  ${1}${RESET}" >&2; exit 1; }

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "This operation modifies system files. Re-run with sudo."
}

check_toml() {
    if [[ ! -f "${TOML}" ]]; then
        mkdir -p "$(dirname "${TOML}")"
        touch "${TOML}"
    fi
}

check_gradle() {
    [[ -f "${BUILD_GRADLE}" ]] || die "App build file not found at ${BUILD_GRADLE}. Is Koinux initialised?"
}

check_gradle_bin() {
    [[ -x "${GRADLE_BIN}" ]] || die "Gradle not found or not executable at ${GRADLE_BIN}."
}

# ── Alias generator ───────────────────────────────────────────────────────────
# io.github.kyant0:backdrop:2.0.0-alpha03  →  kyant0-backdrop
make_alias() {
    local group="${1}"   # io.github.kyant0
    local name="${2}"    # backdrop

    # Last segment of the group, then hyphen-joined with the artifact name
    local group_tail
    group_tail="$(echo "${group}" | awk -F'.' '{print $NF}')"

    # If group tail is redundant (equals name), use second-to-last group segment
    if [[ "${group_tail}" == "${name}" ]]; then
        group_tail="$(echo "${group}" | awk -F'.' '{print $(NF-1)}')"
    fi

    echo "${group_tail}-${name}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g'
}

# ── Alias → Gradle type-safe accessor ────────────────────────────────────────
# kyant0-backdrop  →  libs.kyant0.backdrop
# Every hyphen in the TOML alias becomes a dot in the accessor.
alias_to_accessor() {
    local alias="${1}"
    echo "libs.$(echo "${alias}" | tr '-' '.')"
}

# ── Command: add ──────────────────────────────────────────────────────────────
cmd_add() {
    local input="${1:-}"
    [[ -n "${input}" ]] || die "Usage: kotlib add <group:name:version>"

    # Validate format
    local part_count
    part_count="$(echo "${input}" | awk -F':' '{print NF}')"
    [[ "${part_count}" -eq 3 ]] || die "Expected format <group:name:version>, got: ${input}"

    local group name version alias
    group="$(echo "${input}"   | cut -d: -f1)"
    name="$(echo "${input}"    | cut -d: -f2)"
    version="$(echo "${input}" | cut -d: -f3)"
    alias="$(make_alias "${group}" "${name}")"

    require_root
    check_toml
    check_gradle

    # Collision check
    if grep -qE "^${alias}\s*=" "${TOML}" 2>/dev/null; then
        warn "⚠️  Alias '${alias}' already exists in ${TOML}. Aborting to avoid duplicate."
        exit 1
    fi

    local accessor
    accessor="$(alias_to_accessor "${alias}")"

    info "📦 Adding library..."
    echo "    Alias    : ${BOLD}${alias}${RESET}"
    echo "    Accessor : ${BOLD}${accessor}${RESET}"
    echo "    Group    : ${group}"
    echo "    Name     : ${name}"
    echo "    Version  : ${version}"
    echo ""

    # ── Step 1: Write catalog entry into libs.versions.toml ──────────────────
    local toml_entry
    toml_entry="${alias} = { module = \"${group}:${name}\", version = \"${version}\" }"

    if grep -q '^\[libraries\]' "${TOML}"; then
        sed -i "/^\[libraries\]/a ${toml_entry}" "${TOML}"
    else
        printf '\n[libraries]\n%s\n' "${toml_entry}" >> "${TOML}"
        warn "ℹ️  [libraries] section was missing — created it."
    fi

    info "   ✎ libs.versions.toml updated."

    # ── Step 2: Inject implementation() into build.gradle ────────────────
    local impl_line
    impl_line="    implementation(${accessor})"

    if grep -qF "${accessor}" "${BUILD_GRADLE}"; then
        warn "⚠️  ${accessor} already present in ${BUILD_GRADLE} — skipping implementation line."
    elif grep -q 'dependencies\s*{' "${BUILD_GRADLE}"; then
        # Inject after the first `dependencies {` opening brace
        sed -i "0,/dependencies\s*{/{ /dependencies\s*{/a\\
${impl_line}
}" "${BUILD_GRADLE}"
        info "   ✎ build.gradle updated."
    else
        # No dependencies block exists at all — append one
        printf '\ndependencies {\n%s\n}\n' "${impl_line}" >> "${BUILD_GRADLE}"
        warn "ℹ️  No dependencies {} block found — created one at the end of ${BUILD_GRADLE}."
    fi

    echo ""
    success "✅ ${alias} → ${group}:${name}:${version}"
    success "   implementation(${accessor}) added to build.gradle"
    info "   Run 'kotlib sync' to apply."
}

# ── Command: remove ───────────────────────────────────────────────────────────
cmd_remove() {
    local input="${1:-}"
    [[ -n "${input}" ]] || die "Usage: kotlib remove <group:name:version> OR kotlib remove <alias>"

    require_root
    check_toml
    check_gradle

    local target_alias

    if [[ "${input}" == *:*:* ]]; then
        # Full coordinate — derive alias
        local group name version
        group="$(echo "${input}"   | cut -d: -f1)"
        name="$(echo "${input}"    | cut -d: -f2)"
        version="$(echo "${input}" | cut -d: -f3)"
        target_alias="$(make_alias "${group}" "${name}")"

        info "🗑️  Removing library by coordinate..."
        echo "    Resolved alias: ${BOLD}${target_alias}${RESET}"
    else
        # Direct alias
        target_alias="${input}"
        info "🗑️  Removing library by alias: ${BOLD}${target_alias}${RESET}"
    fi

    echo ""

    # Check it actually exists in the catalog
    if ! grep -qE "^${target_alias}\s*=" "${TOML}"; then
        die "No entry found for alias '${target_alias}' in ${TOML}."
    fi

    local accessor
    accessor="$(alias_to_accessor "${target_alias}")"

    # ── Step 1: Remove from libs.versions.toml ────────────────────────────────
    sed -i "/^${target_alias}\s*=/d" "${TOML}"
    info "   ✎ Removed '${target_alias}' from libs.versions.toml."

    # ── Step 2: Remove implementation() line from build.gradle ───────────
    if grep -qF "${accessor}" "${BUILD_GRADLE}"; then
        # Escape dots for sed's regex engine
        local escaped_accessor
        escaped_accessor="$(echo "${accessor}" | sed 's/\./\\./g')"
        sed -i "/implementation(${escaped_accessor})/d" "${BUILD_GRADLE}"
        info "   ✎ Removed implementation(${accessor}) from build.gradle."
    else
        warn "   ⚠️  No implementation(${accessor}) line found in build.gradle — nothing removed there."
    fi

    echo ""
    success "✅ '${target_alias}' scrubbed from both files."
    info "   Run 'kotlib sync' to apply."
}

# ── Command: --from ───────────────────────────────────────────────────────────
cmd_from() {
    local source_type="${1:-}"
    local url="${2:-}"

    [[ -n "${source_type}" ]] || die "Usage: kotlib --from <maven|jitpack|custom> <url>"
    [[ -n "${url}" ]]         || die "Usage: kotlib --from <maven|jitpack|custom> <url>"

    require_root
    check_gradle

    # Normalise source type label for the comment
    local label
    case "${source_type,,}" in
        maven)   label="Maven" ;;
        jitpack) label="JitPack" ;;
        custom)  label="Custom" ;;
        *)       label="${source_type}" ;;
    esac

    info "🔗 Injecting ${label} repository..."
    echo "    URL: ${url}"
    echo ""

    # Collision check — don't insert the same URL twice
    if grep -qF "${url}" "${SETTINGS_GRADLE}"; then
        warn "⚠️  Repository URL already present in ${SETTINGS_GRADLE}. Skipping."
        exit 0
    fi

    # The block we'll inject (indented 4 spaces to fit inside allprojects/repositories)
    local block
    block="        // ${label} — added by kotlib\n        maven { url \"${url}\" }"

    # Inject inside the first `repositories {` block
    if grep -q 'repositories\s*{' "${SETTINGS_GRADLE}"; then
        sed -i "0,/repositories\s*{/{ /repositories\s*{/a\\
${block}
}" "${SETTINGS_GRADLE}"
    else
        die "No 'repositories {}' block found in ${SETTINGS_GRADLE}. Add one manually first."
    fi

    success "✅ Repository injected into ${SETTINGS_GRADLE}."
    info "   Run 'kotlib sync' to apply."
}

# ── Command: sync ─────────────────────────────────────────────────────────────
cmd_sync() {
    require_root
    check_gradle_bin

    info "🌀 Syncing global Gradle project..."
    echo ""

    local prev_dir="${PWD}"
    cd "${PROJECT_DIR}"
    "${GRADLE_BIN}" --no-daemon build
    cd "${prev_dir}"

    success "✅ Sync complete."
}

# ── Command: clean ────────────────────────────────────────────────────────────
cmd_clean() {
    require_root
    check_gradle_bin

    info "🧹 Purging Gradle caches and cleaning root project..."
    echo ""

    rm -rf "${GRADLE_CACHE}"
    info "   Cache at ${GRADLE_CACHE} — obliterated."

    local prev_dir="${PWD}"
    cd "${PROJECT_DIR}"
    "${GRADLE_BIN}" --no-daemon clean
    cd "${prev_dir}"

    success "✅ Clean complete."
}

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF

${BOLD}kotlib${RESET} — Koinux system-wide Kotlin/Android library manager

${BOLD}USAGE${RESET}
  kotlib add    <group:name:version>          Add a library to libs.versions.toml
  kotlib remove <group:name:version|alias>    Remove a library from libs.versions.toml
  kotlib --from <maven|jitpack|custom> <url>  Inject a maven repo into settings.gradle
  kotlib sync                                 Run the root Gradle build task
  kotlib clean                                Nuke the cache and run Gradle clean

${BOLD}EXAMPLES${RESET}
  sudo kotlib add io.github.kyant0:backdrop:2.0.0-alpha03
  sudo kotlib remove kyant0-backdrop
  sudo kotlib --from jitpack https://jitpack.io
  sudo kotlib sync
  sudo kotlib clean

EOF
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
[[ $# -ge 1 ]] || { usage; exit 0; }

case "${1}" in
    add)         cmd_add    "${2:-}" ;;
    remove|rm)   cmd_remove "${2:-}" ;;
    --from)      cmd_from   "${2:-}" "${3:-}" ;;
    sync)        cmd_sync ;;
    clean)       cmd_clean ;;
    --help|-h)   usage ;;
    *)           die "Unknown command '${1}'. Run 'kotlib --help' for usage." ;;
esac
